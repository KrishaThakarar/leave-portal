# Copy this file to ".env" and fill in real values.
# The .env file is ignored by git so your secrets stay private.

# Port the Express server listens on
PORT=3000

# MongoDB connection string.
# Local MongoDB example:  mongodb://localhost:27017/leave_portal
# MongoDB Atlas example:  mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/leave_portal
MONGO_URI=mongodb://localhost:27017/leave_portal

# Secret used to sign JWT tokens. Use a long, random string in production.
JWT_SECRET=replace_with_a_long_random_secret

# How long a login token stays valid
JWT_EXPIRES_IN=7d
